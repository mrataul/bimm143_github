library(bio3d)
library(bio3dview)
library(NGLVieweR)
pdb_data <- read.pdb(pdbfiles)
pdb_2 <- read.pdb("1H03")
model1 <- biounit(pdb_2)
model2 <- model1[[1]]
view.pdb(pdb_data)
view.pdb(model2)
aln <- struct.aln(fixed = pdb_data, mobile = model2)
aln <- struct.aln(fixed = pdb_data, mobile = model2, web.args = list(email = "keeratsr1@gmail.com"))
library(msa) # Ensure msa is loaded
# ... your previous code to load pdb_data and model2 ...
# 1. Align using the msa package instead of external MUSCLE
aln <- struct.aln(fixed = pdb_data, mobile = model2, exefile = "msa")
# 2. Extract fitted coordinates
fitted_xyz <- aln$xyz
# 3. View both structures overlaid
# Note: view.pdb might work best with specific calls for each object
view.pdb(pdb_data)
view.pdb(model2, xyz = fitted_xyz, add = TRUE)
library(msa) # Ensure msa is loaded
# ... your previous code to load pdb_data and model2 ...
# 1. Align using msa
aln <- struct.aln(fixed = pdb_data, mobile = model2, exefile = "msa")
# 2. CREATE A NEW PDB OBJECT with the fitted coordinates
# We copy model2 but overwrite the coordinates with the aligned ones
model2_fitted <- model2
model2_fitted$xyz <- aln$xyz
# 3. View them
# bio3dview's view.pdb usually takes a single object.
# To see them together, we combine them into one object.
both_together <- cat.pdb(pdb_data, model2_fitted)
view.pdb(both_together)
library(msa) # Ensure msa is loaded
# 1. Align and update coordinates
aln <- struct.aln(fixed = pdb_data, mobile = model2, exefile = "msa")
model2_fitted <- model2
model2_fitted$xyz <- aln$xyz
# 2. Assign unique chain IDs so we can color them separately
pdb_data$atom$chain <- "A"
model2_fitted$atom$chain <- "B"
# 3. Use NGLVieweR for clear, separate coloring
library(NGLVieweR)
NGLVieweR(pdb_data) %>%
addRepresentation("cartoon", param = list(color = "blue")) %>% # Your local PDB
addRepresentation("cartoon", param = list(color = "red", sele = "chain B")) %>% # model2
addStructure(model2_fitted)
library(msa) # Ensure msa is loaded
library(NGLVieweR)
# 1. Prepare your fitted model as before
aln <- struct.aln(fixed = pdb_data, mobile = model2, exefile = "msa")
model2_fitted <- model2
model2_fitted$xyz <- aln$xyz
# 2. Write them to temporary files
tmp1 <- tempfile(fileext = ".pdb")
tmp2 <- tempfile(fileext = ".pdb")
write.pdb(pdb_data, file = tmp1)
write.pdb(model2_fitted, file = tmp2)
# 3. Use the filenames in NGLVieweR
NGLVieweR(tmp1) %>%
addRepresentation("cartoon", param = list(color = "blue")) %>%
addStructure(tmp2) %>%
addRepresentation("cartoon", param = list(color = "red"))
