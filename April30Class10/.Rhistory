library(bio3d)
pdb <- read.pdb("1HSG")
pdb$xyz
head(pdbseq(pdb))
library(bio3dview)
view.pdb(pdb)
view.pdb(pdb, colorScheme = "sse", backgroundColor = "skyblue")
