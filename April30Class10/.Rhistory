id <- "1ake_A"
aa <- get.seq(id)
aa
blast <- blast.pdb(aa)
head(blast$hit.tbl)
hits <- plot(blast)
hits$pdb.id
files <- get.pdb(hits$pdb.id, path="pdbs", split = TRUE, gzip=TRUE)
pdbs <- pdbaln(files, fit=TRUE, exefile="msa")
pdbs
pc <- pca(pdbs)
library(plotly)
plot_ly(as.data.frame(pc$x), x=~PC1, y=~PC2, z=~PC3, type="scatter3d", mode="markers", text=row.names(pc$x), hoverinfo="text")
view.pca(pc)
pc1 <- mktrj(pc, pc=1, file="pc_1.pdb")
pc <- pca(pdbs)
plot(pc)
rd <- rmsd(pdbs)
hc.rd <- hclust(dist(rd))
grps.rd <- cutree(hc.rd, k=3)
plot(pc.xray, 1:2, col="grey50", bg=grps.rd, pch=21, cex=1)
rd <- rmsd(pdbs)
hc.rd <- hclust(dist(rd))
grps.rd <- cutree(hc.rd, k=3)
plot(pc, 1:2, col="grey50", bg=grps.rd, pch=21, cex=1)
