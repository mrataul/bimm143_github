library(pheatmap)
install.packages("pheatmap")
library(pheatmap)
pheatmap( as.matrix(x) )
str(x)
t(x)
pca <- prcomp(t(x))
summary(pca)
# Create a data frame for plotting
df <- as.data.frame(pca$x)
df$Country <- rownames(df)
# Plot PC1 vs PC2 with ggplot
ggplot(pca$x) +
aes(x = pca$x, y = pca$y, label = rownames(pca$x)) +
geom_point(size = 3) +
geom_text(vjust = -0.5) +
xlim(-270, 500) +
xlab("PC1") +
ylab("PC2") +
theme_bw()
