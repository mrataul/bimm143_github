plot_ly(as.data.frame(inst_pca$x), x=~PC1, y=~PC2, z=~PC3, type = "scatter3d", mode="markers", color = artist_label,
colors = c("Mrs. GREEN APPLE" = "green", "Zutomayo" = "purple", "Yorushika" = "skyblue", "zutolive" = "lavender"),
marker = list(size = 4), text=row.names(inst_pca$x), hoverinfo = "text")
p_2d <- plot_ly(as.data.frame(inst_pca$x), x=~PC1, y=~PC2, type = "scatter", mode="markers", color = ~artist_label,
colors = c("Mrs. GREEN APPLE" = "green", "Zutomayo" = "purple", "Yorushika" = "skyblue", "zutolive" = "lavender"),
marker = list(size = 4), text= ~row.names(inst_pca$x), hoverinfo = "text") %>% layout(dragmode='zoom') %>%
config(scrollZoom=TRUE)
plot_ly(as.data.frame(inst_pca$x), x=~PC1, y=~PC3, type = "scatter", mode="markers", color = ~artist_label,
colors = c("Mrs. GREEN APPLE" = "green", "Zutomayo" = "purple", "Yorushika" = "skyblue", "zutolive" = "lavender"),
marker = list(size = 4), text= ~row.names(inst_pca$x), hoverinfo = "text") %>% layout(dragmode='zoom') %>%
config(scrollZoom=TRUE)
ggplot(inst_pca$rotation) +
aes(PC1, reorder(rownames(inst_pca$rotation), PC1)) +
geom_col()
ggplot(inst_pca$rotation) +
aes(PC2, reorder(rownames(inst_pca$rotation), PC2)) +
geom_col()
p_2d
wistwardD2.hclust <- hclust(dist(scale(instrument_input)), method = "ward.D2")
library(dendextend)
# 1. Standard Clustering
dend <- as.dendrogram(wistwardD2.hclust)
# 2. Create the colors (Rainbow based on MPG)
# We use 'rank' to ensure every leaf gets a color from the palette
cols <- rainbow(nrow(instrument_input))[rank(instrument_input$chrom)]
# 3. Apply and Plot
# 'order.dendrogram' ensures color #1 goes to the first leaf on the LEFT
labels_colors(dend) <- cols[order.dendrogram(dend)]
# Force a clean plot
plot(dend, main="Colored Labels")
plot(wistwardD2.hclust, main="Ward D2 Method", hang=-1)
zutomayo <- read.csv("features2.csv", row.names=1)
head(zutomayo)
trueweirdcomparison <- read.csv("AnalysisOfAllFeatures.csv", row.names=1)
songcomparison <- read.csv("features2_artist_flags_fixed.csv", row.names=1)
head(songcomparison)
emotion <- read.csv("tripleemotion.csv", row.names=1)
head(emotion)
library(ggplot2)
library(tidyverse)
my_cols=rep("black", nrow(songcomparison))
my_cols[as.logical(songcomparison$artist)] = "green"
my_cols[as.logical(songcomparison$Zuttomayo)] = "purple"
my_cols[as.logical(songcomparison$artist_yorushika)] = "skyblue"
pca_input <- zutomayo %>%
select(where(is.numeric))
comp_input <- songcomparison %>%
select(where(is.numeric))
library(tidyverse)
pca <- prcomp(pca_input, scale=TRUE)
summary(pca)
compca <- prcomp(comp_input, scale=TRUE)
library(ggrepel)
p1 <- ggplot(pca$x, aes(PC1, PC2, label=row.names(pca$x))) +
geom_point(size = 2, col=my_cols) +
geom_text_repel(size=3.3, max.overlaps = 7) +
labs(legend=zutomayo$artist)
p <- ggplot(compca$x, aes(PC1, PC2, label=row.names(compca$x))) +
geom_point(size=2, col=my_cols) +
geom_text_repel(size=3.3, max.overlaps = 7) +
labs(legend=songcomparison$artist)
library(plotly)
artist_label <- case_when(
as.logical(songcomparison$Zutomayo) ~ "Zutomayo",
as.logical(songcomparison$Mrs.Green.Apple) ~ "Mrs. GREEN APPLE",
as.logical(songcomparison$Yorushika) ~ "Yorushika",
as.logical(songcomparison$Zutomayo.LIVE) ~ "zutolive",
TRUE ~ "Unknown")
##plot_ly(as.data.frame(compca$x), x=~PC1, y=~PC2, z=~PC3, type = "scatter3d", mode="markers", color = artist_label,
#  colors = c("Mrs. GREEN APPLE" = "green", "Zutomayo" = "purple"),
# marker = list(size = 4), text=row.names(compca$x), hoverinfo = "text")
wistwardD2.hclust <- hclust(dist(scale(instrument_input)), method = "ward.D2")
library(dendextend)
# 1. Standard Clustering
dend <- as.dendrogram(wistwardD2.hclust)
# 2. Create the colors (Rainbow based on MPG)
# We use 'rank' to ensure every leaf gets a color from the palette
cols <- rainbow(nrow(instrument_input))[rank(instrument_input$chrom)]
# 3. Apply and Plot
# 'order.dendrogram' ensures color #1 goes to the first leaf on the LEFT
labels_colors(dend) <- cols[order.dendrogram(dend)]
# Force a clean plot
plot(dend, main="Colored Labels")
plot(wistwardD2.hclust, main="Ward D2 Method", hang=-1)
