## Clustering analysis

```{r, fig.height=15, fig.width=80}
wistwardD2.hclust <- hclust(dist(scale(instrument_input)), method = "ward.D2")


library(dendextend)

# 1. Standard Clustering
dend <- as.dendrogram(wistwardD2.hclust)

# 2. Create the colors (Rainbow based on MPG)
# We use 'rank' to ensure every leaf gets a color from the palette
cols <- rainbow(nrow(instrument_input))[rank(instrument_input$chrom)]

# 3. Apply and Plot
# 'order.dendrogram' ensures color #1 goes to the first leaf on the LEFT
labels_colors(dend) <- cols[order.dendrogram(dend)]

# Force a clean plot
plot(dend, main="Colored Labels")

plot(wistwardD2.hclust, main="Ward D2 Method", hang=-1)

```





