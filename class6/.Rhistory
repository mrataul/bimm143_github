generate_dna3 <- function(DNA_len) {
# Returns the >len# of the sequence followed by a line break and then the DNA seq
cat(">", "len", DNA_len, "\n", sample(nucleotides, size=DNA_len, replace=TRUE), collapse="", sep="") #e.g. >len9
}
